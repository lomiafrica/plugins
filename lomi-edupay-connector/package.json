{
  "name": "lomi-edupay-connector",
  "version": "0.1.0",
  "private": true,
  "description": "EduPay × lomi. connector — direct charges for school fee collection",
  "main": "server/index.js",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:client": "node scripts/bundle-client.mjs",
    "dev": "pnpm run build:client && node --watch server/index.js",
    "start": "pnpm run build:client && node server/index.js",
    "verify": "node --check server/index.js && node --check packages/lomi-client/index.js"
  },
  "dependencies": {
    "@edupay/lomi-client": "file:./packages/lomi-client",
    "@lomi./sdk": "^1.5.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
